@@ -22,7 +22,9 @@
   | None -> f ()
 ;;
 
-let required_libs = [ "c10"; "torch_cpu"; "torch_cuda"; "torch" ]
+(* CPU-only build: [torch_cuda] is appended by [choose_dynamic_links] only when
+   [libtorch_cuda.so] is actually present, so it must not be unconditionally required. *)
+let required_libs = [ "c10"; "torch_cpu"; "torch" ]
 
 let choose_dynamic_links ~lib_dir =
   let optional_libs = [ "torch_cuda" ] in
@@ -144,13 +146,13 @@
     C.Flags.write_sexp
       "cxx_flags.sexp"
       (cxx_abi_flag :: (torch_flags.cflags @ cuda_flags.cflags));
-    let torch_flags_lib =
-      if Stdlib.( = ) cuda_flags empty_flags
-      then torch_flags.libs
-      else "-Wl,--no-as-needed" :: torch_flags.libs
-    in
-    let ocaml_flags =
-      ocaml_flags_of_c_flags (torch_flags_lib @ conda_libs @ cuda_flags.libs)
-    in
-    C.Flags.write_sexp "flags.sexp" ocaml_flags)
+    (* Always force [--no-as-needed]: with CPU libtorch the linker would otherwise drop
+       [-ltorch_cpu] etc. when they appear before the objects that reference them. *)
+    let torch_flags_lib = "-Wl,--no-as-needed" :: torch_flags.libs in
+    let link_flags = torch_flags_lib @ conda_libs @ cuda_flags.libs in
+    C.Flags.write_sexp "flags.sexp" (ocaml_flags_of_c_flags link_flags);
+    (* Also expose the raw link flags as [c_library_flags]; dune records those in the
+       library's metadata and propagates them to executables that depend on it, whereas the
+       [-ccopt ...] flags in [(flags)] above are not replayed to downstream links. *)
+    C.Flags.write_sexp "c_library_flags.sexp" link_flags)
 ;;
